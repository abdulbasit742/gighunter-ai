# Server
PORT=3000

# LLM hub
LLM_DEFAULT_PROVIDER=ollama
LLM_DRY_RUN=false
MIN_SCORE_TO_DRAFT=65

# Local Ollama (recommended, zero cost)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:32b
EMBED_MODEL=nomic-embed-text

# Cloud LLM fallbacks (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Platform API credentials (optional)
THEMUSE_API_KEY=
FREELANCER_OAUTH_TOKEN=
UPWORK_OAUTH_TOKEN=

# Daily digest webhook (ClickUp / Slack / Discord incoming webhook URL)
DIGEST_WEBHOOK_URL=

# Built-in daily auto-hunt (runs inside the server process)
SCHEDULE_HUNT=true
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0
