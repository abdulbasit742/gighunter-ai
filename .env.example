# Server
PORT=3000

# LLM hub
LLM_DEFAULT_PROVIDER=ollama
LLM_DRY_RUN=false
MIN_SCORE_TO_DRAFT=65

# Local Ollama (recommended, zero cost)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:32b

# Cloud fallbacks (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
